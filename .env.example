# MCP Transport mode: stdio | streamable-http | both
MCP_TRANSPORT=streamable-http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# SearXNG endpoint (pas dit aan!)
SEARXNG_ENGINE_API_BASE_URL=http://host.docker.internal:8080/search

# Timezone
DESIRED_TIMEZONE=Europe/Amsterdam

# Search tuning
RETURNED_SCRAPPED_PAGES_NO=3
SCRAPPED_PAGES_NO=5
PAGE_CONTENT_WORDS_LIMIT=5000
CITATION_LINKS=True

# Timeouts
TRAFILATURA_TIMEOUT=15
SCRAPING_TIMEOUT=20

# Cache settings
CACHE_MAXSIZE=100
CACHE_TTL_MINUTES=5
CACHE_MAX_AGE_MINUTES=30

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_TIMEOUT_SECONDS=60

# Category limits
MAX_IMAGE_RESULTS=10
MAX_VIDEO_RESULTS=10
MAX_FILE_RESULTS=5
MAX_MAP_RESULTS=5
MAX_SOCIAL_RESULTS=5

# Ignore list (comma-separated domains)
IGNORED_WEBSITES=
